# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# ── Rocket.Chat credentials ───────────────────────────────────────────────
# Generate in Rocket.Chat: My Account → Security → Personal Access Tokens
RC_USER_ID=your_rocketchat_user_id
RC_AUTH_TOKEN=your_personal_access_token

# ── Microsoft Teams / Azure AD app credentials ────────────────────────────
# See DESIGN.md §7 for step-by-step Azure app registration instructions
TEAMS_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TEAMS_CLIENT_ID=yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy
TEAMS_CLIENT_SECRET=your_client_secret_value

# Your personal Azure AD / Entra object ID (NOT the app client_id above).
# Find it: Azure Portal → Azure AD → Users → your account → Object ID
# Used to identify threads you started and detect your @mentions.
TEAMS_ME_USER_ID=zzzzzzzz-zzzz-zzzz-zzzz-zzzzzzzzzzzz

# ── PostgreSQL credentials ────────────────────────────────────────────────
# These are used by both the postgres container (to initialize the DB)
# and the app container (to connect at runtime).
# POSTGRES_HOST should be "postgres" when running inside Docker Compose.
POSTGRES_HOST=postgres
POSTGRES_DB=chat_summarizer
POSTGRES_USER=summarizer
POSTGRES_PASSWORD=change_me_in_production
